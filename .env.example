# Public — exposed to client. Use PUBLIC_ prefix.
PUBLIC_CLOUDINARY_CLOUD_NAME=
PUBLIC_SITE_URL=https://www.crystalinteriors.cz

# Cloudinary admin (server-side only — never PUBLIC_)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin auth
# Email allowed to receive magic-link / access /admin
ADMIN_EMAIL=vodakova@crystalinteriors.cz
# Long random string used to sign JWTs (magic-link tokens + session cookies).
# Generate with:  openssl rand -base64 48
SESSION_SECRET=

# Email provider (Resend). Leave empty in dev — the magic-link URL is printed
# to the server console instead of being emailed.
RESEND_API_KEY=
# Verified "from" address used by Resend.
RESEND_FROM="Crystal Interiors <admin@crystalinteriors.cz>"
