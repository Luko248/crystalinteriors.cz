{
  "version": "2.0.0",
  "name": "crystalinteriors.cz",
  "description": "Crystal Interiors website built with Astro",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "dependencies": {
    "@fancyapps/ui": "^6.1.6",
    "@googlemaps/js-api-loader": "^2.0.2",
    "cloudinary": "^2.8.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.1.1"
  },
  "keywords": [],
  "author": "Lukas Chylik",
  "devDependencies": {
    "@astrojs/check": "^0.9.5",
    "@tailwindcss/cli": "^4.1.17",
    "@toolwind/anchors": "^1.0.10",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^25.0.10",
    "astro": "^5.16.15",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "run-p css:dev astro:dev",
    "start": "bun run dev",
    "build": "bun run css:build && astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "astro:dev": "astro dev",
    "css:dev": "tailwindcss -i public/styles/tailwind.source.css -o public/styles/tailwind.css --watch",
    "css:build": "tailwindcss -i public/styles/tailwind.source.css -o public/styles/tailwind.css --minify"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
