  "license": "UNLICENSED",
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.1",
    "@fancyapps/ui": "^6.1.14",
    "@googlemaps/js-api-loader": "^2.0.2",
    "cloudinary": "^2.10.0",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  },
  "keywords": [],
  "author": "Lukas Chylik",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260517.1",
    "@tailwindcss/cli": "^4.3.0",
    "@toolwind/anchors": "^1.0.10",
    "@types/google.maps": "^3.64.1",
    "@types/node": "^24.10.0",
    "astro": "^6.3.3",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "dev": "run-p css:dev astro:dev",
    "start": "bun run dev",
    "build": "bun run css:build && astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "astro:dev": "astro dev",
    "css:dev": "tailwindcss -i public/styles/tailwind.source.css -o public/styles/tailwind.css --watch",
    "css:build": "tailwindcss -i public/styles/tailwind.source.css -o public/styles/tailwind.css --minify"
  },
  "engines": {
    "node": ">=22.0.0"
  }
