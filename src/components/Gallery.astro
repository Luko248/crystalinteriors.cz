---
import MagnifyIcon from "@/components/icons/MagnifyIcon.astro";

export interface Props {
  images: Array<{
    thumb: string;
    full: string;
    width?: number;
    height?: number;
    alt?: string;
    groupId?: string;
    groupTitle?: string;
    extraItems?: Array<{
      full: string;
      width?: number;
      height?: number;
      alt?: string;
    }>;
  }>;
  galleryId: string;
}

const { images, galleryId } = Astro.props;
---

<div class="py-12">
  <div class="columns-1 sm:columns-2 lg:columns-3 gap-6">
    {
      images.map((img) => {
        const groupId = img.groupId || galleryId;
        const caption = img.alt || img.groupTitle || "";

        return (
          <div class="relative block break-inside-avoid rounded-xl overflow-hidden bg-surface shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 mb-6 animate-reveal">
            <a
              href={img.full}
              data-fancybox={groupId}
              data-caption={caption}
              class="block relative group"
            >
              <img
                src={img.thumb}
                alt={caption}
                width={img.width}
                height={img.height}
                loading="lazy"
                decoding="async"
                class="w-full h-auto transform transition-transform duration-500 group-hover:scale-110"
              />

              <div class="flex w-auto max-w-[calc(100%-2rem)] flex-nowrap gap-2 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 items-center justify-center p-4 text-white rounded-full bg-black/20 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <MagnifyIcon class="w-6 h-6 min-w-6 min-h-6" />
                <span class="font-semibold tracking-wide text-lg sm:text-xl leading-none whitespace-nowrap">
                  {caption}
                </span>
              </div>
            </a>

            {img.extraItems &&
              img.extraItems.map((extra) => (
                <a
                  href={extra.full}
                  data-fancybox={groupId}
                  data-caption={extra.alt || caption}
                  class="hidden"
                />
              ))}
          </div>
        );
      })
    }
  </div>
</div>

<script>
  import { Fancybox } from "@fancyapps/ui";
  import "@fancyapps/ui/dist/fancybox/fancybox.css";

  const bindFancybox = () => {
    Fancybox.bind("[data-fancybox]", {
      Hash: true,
      Toolbar: {
        display: {
          left: ["infobar"],
          middle: [],
          right: ["slideshow", "thumbs", "close"],
        },
      },
      Images: {
        zoom: true,
      },
    } as any);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bindFancybox, { once: true });
  } else {
    bindFancybox();
  }

  document.addEventListener("astro:page-load", bindFancybox);
</script>
