---
import { site } from "@/data/site";
import { cloudinaryImage } from "@/lib/cloudinary";
import { withBase } from "@/lib/navigation";
import Button from "./ui/Button.astro";
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__media" aria-hidden="true">
    <img
      src={cloudinaryImage(site.hero.image, { width: 1800, height: 1200, fit: "fill" })}
      alt=""
      width="1800"
      height="1200"
      class="hero__image"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    <div class="space-y-8 text-white">
      <p class="inline-flex items-center gap-3 text-xs font-medium uppercase tracking-overline text-white/72">
        <span class="h-px w-10 bg-white/40"></span>
        {site.hero.eyebrow}
        <span class="h-px w-10 bg-white/40"></span>
      </p>
      <h1
        id="hero-title"
        class="mx-auto max-w-4xl text-balance text-4xl leading-[1.08] tracking-tight md:text-6xl lg:text-7xl"
      >
        {site.hero.title}
      </h1>
      <p class="mx-auto max-w-2xl text-balance text-lg leading-8 text-white/82 md:text-xl">
        {site.hero.text}
      </p>
      <div class="flex flex-col items-center justify-center gap-3 pt-4 sm:flex-row sm:flex-wrap">
        <Button
          as="a"
          href={withBase(site.hero.primaryCta.href)}
          variant="hero-primary"
          size="lg"
          rel={undefined}
          class="min-h-13 min-w-[220px] justify-center"
        >
          {site.hero.primaryCta.label}
        </Button>
        <Button
          as="a"
          href={withBase(site.hero.secondaryCta.href)}
          variant="hero-outline"
          size="lg"
          rel={undefined}
          class="min-h-13 min-w-[220px] justify-center"
        >
          {site.hero.secondaryCta.label}
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }

  .hero__media {
    position: absolute;
    inset: 0;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.05);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__image {
      animation: hero-zoom 18s var(--ease-out-soft) forwards;
    }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse at center,
        color-mix(in oklch, var(--color-ink-deep) 55%, transparent) 0%,
        color-mix(in oklch, var(--color-ink-deep) 78%, transparent) 55%,
        color-mix(in oklch, var(--color-ink-deep) 92%, transparent) 100%
      ),
      radial-gradient(
        circle at top,
        color-mix(in oklch, var(--color-accent) 22%, transparent),
        transparent 45%
      ),
      radial-gradient(
        circle at bottom,
        color-mix(in oklch, var(--color-white) 6%, transparent),
        transparent 42%
      );
  }

  .hero__content {
    position: relative;
    max-width: 64rem;
    margin: 0 auto;
    min-height: 88svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: calc(var(--spacing) * 28) calc(var(--spacing) * 4);
    text-align: center;
  }

  @media (min-width: 640px) {
    .hero__content {
      padding-inline: calc(var(--spacing) * 6);
    }
  }

  @media (min-width: 768px) {
    .hero__content {
      min-height: 92svh;
    }
  }

  @media (min-width: 1024px) {
    .hero__content {
      padding-inline: calc(var(--spacing) * 8);
    }
  }

  @keyframes hero-zoom {
    from {
      transform: scale(1.08);
    }
    to {
      transform: scale(1);
    }
  }
</style>
