---
import { site } from "@/data/site";
import { cloudinaryImage } from "@/lib/cloudinary";
import { withBase } from "@/lib/navigation";
import Button from "./ui/Button.astro";
---

<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0">
    <img
      src={cloudinaryImage(site.hero.image, { width: 1800, height: 1200, fit: "fill" })}
      alt="Návrh moderního interiéru od Crystal Interiors"
      class="h-full w-full scale-105 object-cover motion-safe:animate-[hero-zoom_18s_ease-out_forwards]"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(14,14,13,0.55)_0%,rgba(14,14,13,0.78)_55%,rgba(14,14,13,0.92)_100%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(173,141,94,0.22),transparent_45%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom,rgba(255,255,255,0.06),transparent_42%)]"></div>
  </div>

  <div class="relative mx-auto flex min-h-[88svh] max-w-5xl flex-col items-center justify-center px-4 py-28 text-center sm:px-6 md:min-h-[92svh] lg:px-8">
    <div class="space-y-8 text-white">
      <p class="inline-flex items-center gap-3 text-xs font-medium uppercase tracking-[0.36em] text-white/72">
        <span class="h-px w-10 bg-white/40"></span>
        {site.hero.eyebrow}
        <span class="h-px w-10 bg-white/40"></span>
      </p>
      <h1 class="mx-auto max-w-4xl text-balance text-4xl leading-[1.08] tracking-tight md:text-6xl lg:text-7xl">
        {site.hero.title}
      </h1>
      <p class="mx-auto max-w-2xl text-balance text-lg leading-8 text-white/82 md:text-xl">
        {site.hero.text}
      </p>
      <div class="flex flex-col items-center justify-center gap-3 pt-4 sm:flex-row sm:flex-wrap">
        <Button
          as="a"
          href={withBase(site.hero.primaryCta.href)}
          variant="hero-primary"
          size="lg"
          rel={undefined}
          class="min-h-13 min-w-[220px] justify-center"
        >
          {site.hero.primaryCta.label}
        </Button>
        <Button
          as="a"
          href={withBase(site.hero.secondaryCta.href)}
          variant="hero-outline"
          size="lg"
          rel={undefined}
          class="min-h-13 min-w-[220px] justify-center border-white/34 text-white hover:border-white hover:bg-white/10 hover:text-white"
        >
          {site.hero.secondaryCta.label}
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes hero-zoom {
    from {
      transform: scale(1.08);
    }
    to {
      transform: scale(1);
    }
  }
</style>
