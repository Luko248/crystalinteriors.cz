---
import { site } from "@/data/site";
import { cloudinaryImage } from "@/lib/cloudinary";
import { withBase } from "@/lib/navigation";
import Button from "./ui/Button.astro";
---

<section class="relative isolate overflow-hidden" aria-labelledby="hero-title">
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src={cloudinaryImage(site.hero.image, { width: 1800, height: 1200, fit: "fill" })}
      alt=""
      width="1800"
      height="1200"
      class="h-full w-full scale-105 object-cover motion-safe:animate-hero-zoom"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="hero__overlay absolute inset-0"></div>
  </div>

  <div class="relative mx-auto flex min-h-[78svh] max-w-4xl flex-col items-center justify-center px-4 py-20 text-center sm:min-h-[86svh] sm:px-6 sm:py-28 md:min-h-[92svh] lg:px-8">
    <div class="space-y-6 text-white sm:space-y-8">
      <p class="inline-flex items-center gap-3 text-xs font-medium uppercase tracking-overline text-white/72">
        <span class="h-px w-8 bg-white/40 sm:w-10"></span>
        {site.hero.eyebrow}
        <span class="h-px w-8 bg-white/40 sm:w-10"></span>
      </p>
      <h1
        id="hero-title"
        class="mx-auto max-w-4xl text-balance text-3xl leading-[1.08] tracking-tight sm:text-4xl md:text-6xl lg:text-7xl"
      >
        {site.hero.title}
      </h1>
      <p class="mx-auto max-w-2xl text-balance text-base leading-7 text-white/82 sm:text-lg sm:leading-8 md:text-xl">
        {site.hero.text}
      </p>
      <div class="flex w-full flex-col items-stretch justify-center gap-3 pt-4 sm:w-auto sm:flex-row sm:flex-wrap sm:items-center">
        <Button
          as="a"
          href={withBase(site.hero.primaryCta.href)}
          variant="hero-primary"
          size="lg"
          fullWidth
          rel={undefined}
          class="justify-center sm:min-w-[220px]"
        >
          {site.hero.primaryCta.label}
        </Button>
        <Button
          as="a"
          href={withBase(site.hero.secondaryCta.href)}
          variant="hero-outline"
          size="lg"
          fullWidth
          rel={undefined}
          class="justify-center sm:min-w-[220px]"
        >
          {site.hero.secondaryCta.label}
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  /* Multi-stop radial gradient overlay using ink + accent tokens.
     Tailwind can't express layered color-mix() radials inline. */
  .hero__overlay {
    background:
      radial-gradient(
        ellipse at center,
        color-mix(in oklch, var(--color-ink-deep) 55%, transparent) 0%,
        color-mix(in oklch, var(--color-ink-deep) 78%, transparent) 55%,
        color-mix(in oklch, var(--color-ink-deep) 92%, transparent) 100%
      ),
      radial-gradient(
        circle at top,
        color-mix(in oklch, var(--color-accent) 22%, transparent),
        transparent 45%
      ),
      radial-gradient(
        circle at bottom,
        color-mix(in oklch, var(--color-white) 6%, transparent),
        transparent 42%
      );
  }
</style>
