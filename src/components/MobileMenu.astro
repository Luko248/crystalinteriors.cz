---
import { site } from "@/data/site";
import { withBase } from "@/lib/navigation";

export interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const activePath =
  pathname === "/" ? "/" : pathname.endsWith("/") ? pathname : `${pathname}/`;
const primaryPhone = site.company.phones[0]?.replace(/\s+/g, "") ?? "";
---

<div class="mobile-menu lg:hidden" data-mobile-menu data-state="closed">
  <button
    type="button"
    class="mobile-menu__toggle glass"
    data-mobile-menu-toggle
    aria-controls="mobile-menu-panel"
    aria-expanded="false"
    aria-label="Otevřít navigaci"
  >
    <span class="mobile-menu__icon" aria-hidden="true">
      <span class="mobile-menu__bar"></span>
      <span class="mobile-menu__bar"></span>
      <span class="mobile-menu__bar"></span>
    </span>
    <span class="sr-only" data-mobile-menu-label>Otevřít navigaci</span>
  </button>

  <div
    id="mobile-menu-panel"
    class="mobile-menu__panel"
    role="dialog"
    aria-modal="true"
    aria-label="Hlavní navigace"
    tabindex="-1"
    inert
  >
    <div class="mobile-menu__backdrop" aria-hidden="true"></div>

    <div class="mobile-menu__sheet glass-strong">
      <nav class="mobile-menu__nav" aria-label="Hlavní navigace">
        <ul class="mobile-menu__list">
          {
            site.nav.map((item, index) => {
              const isActive = activePath === item.href;
              return (
                <li class="mobile-menu__item" style={`--i:${index};`}>
                  <a
                    href={withBase(item.href)}
                    class="mobile-menu__link"
                    aria-current={isActive ? "page" : undefined}
                    data-mobile-menu-link
                  >
                    <span class="mobile-menu__index">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <span class="mobile-menu__label">{item.label}</span>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>

      <div class="mobile-menu__footer">
        <a
          href={withBase("/kontakt/")}
          class="mobile-menu__cta"
          data-mobile-menu-link
        >
          Kontaktujte nás
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
              clip-rule="evenodd"
            />
          </svg>
        </a>

        {
          primaryPhone && (
            <a
              href={`tel:${primaryPhone}`}
              class="mobile-menu__secondary"
              data-mobile-menu-link
              aria-label={`Zavolat na ${site.company.phones[0]}`}
            >
              {site.company.phones[0]}
            </a>
          )
        }

        <ul class="mobile-menu__social" aria-label="Sociální sítě">
          <li>
            <a
              href={site.social.facebook}
              target="_blank"
              rel="noreferrer"
              class="mobile-menu__social-link"
              aria-label="Facebook (otevře se v novém okně)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path d="M22 12.06C22 6.51 17.52 2 12 2S2 6.51 2 12.06c0 5 3.66 9.14 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.91h-2.34V22c4.78-.8 8.43-4.94 8.43-9.94z" />
              </svg>
              <span>Facebook</span>
            </a>
          </li>
          <li>
            <a
              href={site.social.instagram}
              target="_blank"
              rel="noreferrer"
              class="mobile-menu__social-link"
              aria-label="Instagram (otevře se v novém okně)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
              </svg>
              <span>Instagram</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
  .mobile-menu {
    position: relative;
  }

  .mobile-menu__toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.75rem;
    width: 2.75rem;
    border-radius: var(--radius-full);
    color: var(--color-foreground);
    cursor: pointer;
    z-index: 60;
  }

  .mobile-menu__icon {
    position: relative;
    display: block;
    width: 1.25rem;
    height: 1rem;
  }

  .mobile-menu__bar {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background-color: currentColor;
    border-radius: 999px;
    transition:
      transform var(--duration-standard) var(--ease-out-soft),
      opacity var(--duration-fast) var(--ease-standard),
      top var(--duration-standard) var(--ease-out-soft);
    transform-origin: center;
  }

  .mobile-menu__bar:nth-child(1) {
    top: 0;
  }
  .mobile-menu__bar:nth-child(2) {
    top: 50%;
    transform: translateY(-50%);
  }
  .mobile-menu__bar:nth-child(3) {
    bottom: 0;
  }

  [data-state="open"] .mobile-menu__bar:nth-child(1) {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }
  [data-state="open"] .mobile-menu__bar:nth-child(2) {
    opacity: 0;
    transform: translateY(-50%) scaleX(0);
  }
  [data-state="open"] .mobile-menu__bar:nth-child(3) {
    bottom: 50%;
    transform: translateY(50%) rotate(-45deg);
  }

  .mobile-menu__panel {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    display: flex;
    flex-direction: column;
    pointer-events: none;
  }

  .mobile-menu__panel[inert] {
    visibility: hidden;
  }

  [data-state="open"] .mobile-menu__panel {
    pointer-events: auto;
  }

  .mobile-menu__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in oklch, var(--color-ink-deep) 70%, transparent);
    opacity: 0;
    transition: opacity var(--duration-standard) var(--ease-out-soft);
  }

  [data-state="open"] .mobile-menu__backdrop {
    opacity: 1;
  }

  .mobile-menu__sheet {
    position: relative;
    margin: auto;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: calc(var(--spacing) * 8);
    padding: calc(var(--spacing) * 24) calc(var(--spacing) * 6)
      calc(var(--spacing) * 10);
    overflow-y: auto;
    transform: translateY(-100%);
    opacity: 0;
    transition:
      transform var(--duration-slow) var(--ease-out-soft),
      opacity var(--duration-standard) var(--ease-standard);
    border-radius: 0;
  }

  [data-state="open"] .mobile-menu__sheet {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-menu__nav {
    flex: 1;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .mobile-menu__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 2);
    width: 100%;
  }

  .mobile-menu__item {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity var(--duration-standard) var(--ease-out-soft)
        calc(var(--i, 0) * 60ms + 120ms),
      transform var(--duration-standard) var(--ease-out-soft)
        calc(var(--i, 0) * 60ms + 120ms);
  }

  [data-state="open"] .mobile-menu__item {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu__link {
    display: flex;
    align-items: baseline;
    gap: calc(var(--spacing) * 4);
    padding: calc(var(--spacing) * 3) 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 9vw, 3.5rem);
    line-height: 1.05;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-menu__link[aria-current="page"] {
    color: var(--color-primary);
  }

  .mobile-menu__link:hover .mobile-menu__label,
  .mobile-menu__link:focus-visible .mobile-menu__label {
    color: var(--color-primary);
  }

  .mobile-menu__index {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .mobile-menu__label {
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .mobile-menu__footer {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 4);
  }

  .mobile-menu__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: calc(var(--spacing) * 2);
    padding: calc(var(--spacing) * 4) calc(var(--spacing) * 6);
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: var(--shadow-lifted);
  }

  .mobile-menu__cta:hover,
  .mobile-menu__cta:focus-visible {
    background: var(--color-primary-hover);
  }

  .mobile-menu__secondary {
    text-align: center;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .mobile-menu__secondary:hover,
  .mobile-menu__secondary:focus-visible {
    color: var(--color-foreground);
  }

  .mobile-menu__social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: calc(var(--spacing) * 4);
    border-top: 1px solid var(--color-border);
    padding-top: calc(var(--spacing) * 4);
  }

  .mobile-menu__social-link {
    display: inline-flex;
    align-items: center;
    gap: calc(var(--spacing) * 2);
    padding: calc(var(--spacing) * 2) calc(var(--spacing) * 3);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .mobile-menu__social-link:hover,
  .mobile-menu__social-link:focus-visible {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu__sheet,
    .mobile-menu__backdrop,
    .mobile-menu__item,
    .mobile-menu__bar {
      transition: none;
    }
  }
</style>

<script>
  const init = () => {
    const root = document.querySelector<HTMLElement>("[data-mobile-menu]");
    if (!root || (root as any).__mobileMenuInit) return;
    (root as any).__mobileMenuInit = true;

    const toggle = root.querySelector<HTMLButtonElement>(
      "[data-mobile-menu-toggle]",
    );
    const panel = root.querySelector<HTMLElement>(".mobile-menu__panel");
    const backdrop = root.querySelector<HTMLElement>(".mobile-menu__backdrop");
    const links = root.querySelectorAll<HTMLAnchorElement>(
      "[data-mobile-menu-link]",
    );
    const label = root.querySelector<HTMLElement>("[data-mobile-menu-label]");

    if (!toggle || !panel) return;

    const setState = (open: boolean) => {
      root.dataset.state = open ? "open" : "closed";
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute(
        "aria-label",
        open ? "Zavřít navigaci" : "Otevřít navigaci",
      );
      if (label) {
        label.textContent = open ? "Zavřít navigaci" : "Otevřít navigaci";
      }
      if (open) {
        panel.removeAttribute("inert");
        document.body.setAttribute("data-scroll-lock", "");
        panel.focus({ preventScroll: true });
      } else {
        panel.setAttribute("inert", "");
        document.body.removeAttribute("data-scroll-lock");
        toggle.focus({ preventScroll: true });
      }
    };

    toggle.addEventListener("click", () => {
      setState(root.dataset.state !== "open");
    });

    backdrop?.addEventListener("click", () => setState(false));

    links.forEach((link) => {
      link.addEventListener("click", () => setState(false));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && root.dataset.state === "open") {
        setState(false);
      }
    });

    const mq = window.matchMedia("(min-width: 1024px)");
    const handleResize = () => {
      if (mq.matches && root.dataset.state === "open") setState(false);
    };
    mq.addEventListener("change", handleResize);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
  document.addEventListener("astro:page-load", init);
</script>
