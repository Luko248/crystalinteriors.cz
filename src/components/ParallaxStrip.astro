---
export interface Props {
  image: string;
  eyebrow?: string;
  title: string;
  text?: string;
  /** Background overlay tone — "light" tints with white, "dark" tints with ink. */
  tone?: "light" | "dark";
  height?: "sm" | "md" | "lg";
  class?: string;
}

const {
  image,
  eyebrow,
  title,
  text,
  tone = "dark",
  height = "md",
  class: className = "",
} = Astro.props as Props;

const heightClass =
  height === "sm"
    ? "min-h-[220px] sm:min-h-[280px]"
    : height === "lg"
      ? "min-h-[360px] sm:min-h-[480px] lg:min-h-[560px]"
      : "min-h-[280px] sm:min-h-[360px] lg:min-h-[420px]";

const textColor = tone === "dark" ? "text-white" : "text-foreground";
const eyebrowColor = tone === "dark" ? "text-white/72" : "text-primary";
const overlayClass = tone === "dark" ? "parallax-strip__overlay--dark" : "parallax-strip__overlay--light";
---

<section
  class:list={[
    "parallax-strip relative isolate flex w-full items-center justify-center overflow-hidden",
    heightClass,
    className,
  ]}
  style={`--parallax-image: url('${image}');`}
  aria-label={title}
>
  <div class:list={["parallax-strip__overlay absolute inset-0 z-0", overlayClass]} aria-hidden="true"></div>

  <div class:list={["relative z-10 mx-auto max-w-3xl px-4 py-12 text-center sm:px-6 sm:py-16 lg:px-8", textColor]}>
    {eyebrow && (
      <p class:list={["text-xs font-medium uppercase tracking-overline sm:text-sm sm:tracking-eyebrow", eyebrowColor]}>
        {eyebrow}
      </p>
    )}
    <h2 class="mt-3 text-3xl leading-tight tracking-tight sm:text-4xl md:text-5xl">
      {title}
    </h2>
    {text && (
      <p class:list={["mx-auto mt-4 max-w-2xl text-base leading-7 sm:text-lg sm:leading-8", tone === "dark" ? "text-white/82" : "text-muted"]}>
        {text}
      </p>
    )}
  </div>
</section>

<style>
  /* Parallax via background-attachment: fixed.
     Image stays in viewport while the section scrolls past it.
     On iOS Safari (mobile), `fixed` is unreliable — fall back to
     `scroll` under the hover/pointer media query for touch devices. */
  .parallax-strip {
    background-image: var(--parallax-image);
    background-position: center center;
    background-size: cover;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }

  @media (hover: none), (max-width: 768px) {
    .parallax-strip {
      background-attachment: scroll;
    }
  }

  .parallax-strip__overlay--dark {
    background: linear-gradient(
      to bottom,
      color-mix(in oklch, var(--color-ink-deep) 55%, transparent),
      color-mix(in oklch, var(--color-ink-deep) 35%, transparent)
    );
  }

  .parallax-strip__overlay--light {
    background: linear-gradient(
      to bottom,
      color-mix(in oklch, var(--color-white) 35%, transparent),
      color-mix(in oklch, var(--color-white) 15%, transparent)
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .parallax-strip {
      background-attachment: scroll;
    }
  }
</style>
