---
export interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: "left" | "center";
  headingId?: string;
}

const { eyebrow, title, text, align = "left", headingId } = Astro.props;
const centered = align === "center";
---

<div class:list={["space-y-4", centered && "mx-auto max-w-3xl text-center"]}>
  {eyebrow && (
    <p class="text-sm font-medium uppercase tracking-eyebrow text-primary">
      {eyebrow}
    </p>
  )}
  <h2 id={headingId} class="text-2xl leading-tight text-foreground sm:text-3xl md:text-5xl">{title}</h2>
  {text && <p class:list={["text-base leading-7 text-muted sm:text-lg sm:leading-8", !centered && "max-w-3xl"]}>{text}</p>}
</div>
