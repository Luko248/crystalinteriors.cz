---
import { site } from "@/data/site";
import { withBase } from "@/lib/navigation";
---

<footer class="border-t border-black/8 bg-white/70 py-12 dark:border-white/8 dark:bg-[#121210]">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 md:grid-cols-[1.2fr_1fr_1fr] md:items-start lg:px-8">
    <div class="space-y-2">
      <p class="text-sm font-medium uppercase tracking-[0.24em] text-primary">
        {site.name}
      </p>
      <p class="text-sm leading-6 text-muted">
        Interiéry a nábytek na míru pro byty, domy i komerční prostory.
      </p>
    </div>

    <div class="space-y-1">
      <p class="text-xs uppercase tracking-[0.18em] text-muted">Ateliér</p>
      <p class="text-sm leading-6 text-foreground">{site.company.address}</p>
      <a
        href={withBase("/kontakt/")}
        class="inline-block text-sm text-primary hover:underline"
      >
        Kontakt &rarr;
      </a>
    </div>

    <div class="space-y-1 md:text-right">
      <p class="text-xs uppercase tracking-[0.18em] text-muted">Sledujte nás</p>
      <div class="flex gap-4 md:justify-end">
        <a href={site.social.facebook} target="_blank" rel="noreferrer" class="text-sm text-foreground hover:text-primary">
          Facebook
        </a>
        <a href={site.social.instagram} target="_blank" rel="noreferrer" class="text-sm text-foreground hover:text-primary">
          Instagram
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto mt-10 max-w-7xl border-t border-black/8 px-4 pt-6 text-xs text-muted dark:border-white/8 sm:px-6 lg:px-8">
    <p>© {new Date().getFullYear()} {site.name}. Všechna práva vyhrazena.</p>
  </div>
</footer>
