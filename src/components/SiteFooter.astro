---
import { site } from "@/data/site";
import { withBase } from "@/lib/navigation";
---

<footer
  class="border-t border-border bg-surface/60 py-10 sm:py-12"
  aria-labelledby="site-footer-heading"
>
  <h2 id="site-footer-heading" class="sr-only">Patička stránky</h2>
  <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:grid-cols-2 sm:px-6 md:grid-cols-[1.2fr_1fr_1fr] md:items-start lg:px-8">
    <div class="space-y-2 sm:col-span-2 md:col-span-1">
      <p class="text-sm font-medium uppercase tracking-eyebrow text-primary">
        {site.name}
      </p>
      <p class="text-sm leading-6 text-muted">
        Interiéry a nábytek na míru pro byty, domy i komerční prostory.
      </p>
    </div>

    <div class="space-y-1">
      <p class="text-xs uppercase tracking-eyebrow text-muted">Ateliér</p>
      <p class="text-sm leading-6 text-foreground">{site.company.address}</p>
      <a
        href={withBase("/kontakt/")}
        class="inline-block text-sm text-primary hover:underline"
        aria-label="Přejít na kontaktní stránku"
      >
        Kontakt &rarr;
      </a>
    </div>

    <nav class="space-y-1 md:text-right" aria-label="Sociální sítě">
      <p class="text-xs uppercase tracking-eyebrow text-muted">Sledujte nás</p>
      <ul class="flex list-none gap-4 md:justify-end">
        <li>
          <a
            href={site.social.facebook}
            target="_blank"
            rel="noreferrer"
            class="text-sm text-foreground hover:text-primary"
            aria-label={`${site.name} na Facebooku (otevře se v novém okně)`}
          >
            Facebook
          </a>
        </li>
        <li>
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noreferrer"
            class="text-sm text-foreground hover:text-primary"
            aria-label={`${site.name} na Instagramu (otevře se v novém okně)`}
          >
            Instagram
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <div class="mx-auto mt-8 max-w-7xl border-t border-border px-4 pt-6 text-xs text-muted sm:mt-10 sm:px-6 lg:px-8">
    <p>© {new Date().getFullYear()} {site.name}. Všechna práva vyhrazena.</p>
  </div>
</footer>
