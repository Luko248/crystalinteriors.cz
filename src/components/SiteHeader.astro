---
import { site } from "@/data/site";
import { withBase } from "@/lib/navigation";
import MobileMenu from "./MobileMenu.astro";
import ThemeToggle from "./ThemeToggle.astro";

export interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const activePath =
  pathname === "/" ? "/" : pathname.endsWith("/") ? pathname : `${pathname}/`;
---

<header class="glass sticky top-0 z-[var(--z-header)] border-b border-border">
  <div class="mx-auto flex max-w-7xl items-center gap-4 px-4 py-3 sm:px-6 lg:gap-8 lg:px-8">
    <a
      href={withBase("/")}
      class="flex shrink-0 items-center gap-3 pr-2 no-underline"
      aria-label={`${site.name} — domovská stránka`}
    >
      <img
        src={withBase("/images/logos/crystalinteriors_logo-white.svg")}
        alt=""
        width="64"
        height="64"
        class="h-12 w-12 object-contain dark:[filter:none] [filter:invert(1)_brightness(0.2)] sm:h-14 sm:w-14"
        loading="eager"
        decoding="async"
      />
      <span class="flex flex-col">
        <span class="text-[0.75rem] font-semibold uppercase tracking-eyebrow text-primary sm:text-[0.8rem]">
          {site.name}
        </span>
        <span class="hidden text-sm leading-snug text-muted sm:block">
          Interiéry a nábytek na míru
        </span>
      </span>
    </a>

    <nav class="ml-auto hidden items-center gap-6 lg:flex xl:gap-8" aria-label="Hlavní navigace">
      {
        site.nav.map((item) => {
          const isActive = activePath === item.href;
          return (
            <a
              href={withBase(item.href)}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "whitespace-nowrap text-sm no-underline transition-colors duration-fast ease-standard hover:text-foreground",
                isActive ? "text-foreground" : "text-muted",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
      <ThemeToggle />
    </nav>

    <div class="ml-auto flex items-center gap-2 lg:hidden">
      <ThemeToggle />
      <MobileMenu pathname={pathname} />
    </div>
  </div>
</header>
