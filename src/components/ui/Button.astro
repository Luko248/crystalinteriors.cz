---
import { tv } from "tailwind-variants";

export interface Props {
  as?: "a" | "button";
  href?: string;
  rel?: string;
  variant?:
    | "primary"
    | "secondary"
    | "ghost"
    | "outline"
    | "hero-primary"
    | "hero-outline";
  size?: "sm" | "md" | "lg";
  disabled?: boolean;
  class?: string;
}

const props = Astro.props as Props;
const {
  as = "a",
  href = undefined,
  rel = "nofollow",
  variant = "primary",
  size = "md",
  disabled = false,
  class: className = "",
} = props;

const button = tv({
  base: "inline-flex items-center justify-center gap-2 rounded-md font-medium whitespace-nowrap focus-visible:outline-none disabled:opacity-50 disabled:pointer-events-none motion-safe:transition-all motion-reduce:transition-none duration-300 ease-standard",
  variants: {
    variant: {
      primary:
        "bg-[var(--color-primary)] text-[var(--color-white)] hover:bg-[var(--color-primary-hover)] shadow-sm hover:shadow-md",
      secondary:
        "bg-[var(--color-secondary)] text-[var(--color-foreground)] hover:bg-[var(--color-secondary-hover)] shadow-sm hover:shadow-md",
      outline:
        "bg-transparent border border-[var(--color-primary)] text-[var(--color-foreground)] hover:bg-[var(--color-primary)] hover:text-[var(--color-white)]",
      ghost:
        "bg-transparent text-[var(--color-foreground)] hover:bg-black/5 dark:hover:bg-white/10",
      "hero-primary":
        "border border-[var(--color-primary)] bg-[var(--color-primary)] text-[var(--color-white)] shadow-lg transition-shadow duration-300 text-lg uppercase tracking-[0.14em] hover:bg-[var(--color-primary-hover)] focus-visible:ring-2 focus-visible:ring-white/80 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent",
      "hero-outline":
        "bg-transparent border backdrop-blur-sm text-[var(--color-white)] text-lg uppercase tracking-[0.14em] focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-transparent",
    },
    size: {
      sm: "px-3 py-1.5 text-xs md:px-4 md:py-2 md:text-sm",
      md: "px-5 py-2.5 text-sm md:px-6 md:py-3 md:text-base",
      lg: "px-6 py-3 text-base md:px-8 md:py-4 md:text-lg",
    },
  },
  defaultVariants: {
    variant: "primary",
    size: "md",
  },
});

const classes = button({ variant, size, class: className });
---

{
  as === "a" ? (
    <a class={classes} href={href} rel={rel}>
      <slot />
    </a>
  ) : (
    <button class={classes} disabled={disabled}>
      <slot />
    </button>
  )
}
