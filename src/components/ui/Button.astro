---
import { tv } from "tailwind-variants";

export interface Props {
  as?: "a" | "button";
  href?: string;
  rel?: string;
  variant?:
    | "primary"
    | "secondary"
    | "ghost"
    | "outline"
    | "outline-on-dark"
    | "hero-primary"
    | "hero-outline";
  size?: "sm" | "md" | "lg";
  fullWidth?: boolean;
  disabled?: boolean;
  class?: string;
}

const props = Astro.props as Props;
const {
  as = "a",
  href = undefined,
  rel = "nofollow",
  variant = "primary",
  size = "md",
  fullWidth = false,
  disabled = false,
  class: className = "",
} = props;

const button = tv({
  base: "inline-flex items-center justify-center gap-2 rounded-md font-medium whitespace-nowrap min-h-11 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background disabled:opacity-50 disabled:pointer-events-none motion-safe:transition-all motion-reduce:transition-none duration-300 ease-standard",
  variants: {
    variant: {
      primary:
        "bg-primary text-white hover:bg-primary-hover shadow-card hover:shadow-lifted",
      secondary:
        "bg-secondary text-foreground hover:bg-secondary-hover shadow-card hover:shadow-lifted",
      outline:
        "bg-transparent border border-primary text-foreground hover:bg-primary hover:text-white",
      "outline-on-dark":
        "bg-transparent border border-white/40 text-white hover:border-white hover:bg-white/10 focus-visible:ring-white focus-visible:ring-offset-transparent",
      ghost:
        "bg-transparent text-foreground hover:bg-black/5 dark:hover:bg-white/10",
      "hero-primary":
        "border border-primary bg-primary text-white shadow-lifted text-base md:text-lg uppercase tracking-button hover:bg-primary-hover focus-visible:ring-2 focus-visible:ring-white/80 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent",
      "hero-outline":
        "bg-transparent border border-white/34 text-white backdrop-blur-sm text-base md:text-lg uppercase tracking-button hover:border-white hover:bg-white/10 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-transparent",
    },
    size: {
      sm: "px-4 py-2 text-sm md:text-sm",
      md: "px-5 py-2.5 text-sm md:px-6 md:py-3 md:text-base",
      lg: "px-6 py-3 text-base md:px-8 md:py-4 md:text-lg",
    },
    fullWidth: {
      true: "w-full sm:w-auto",
      false: "",
    },
  },
  defaultVariants: {
    variant: "primary",
    size: "md",
    fullWidth: false,
  },
});

const classes = button({ variant, size, fullWidth, class: className });
---

{
  as === "a" ? (
    <a class={classes} href={href} rel={rel}>
      <slot />
    </a>
  ) : (
    <button class={classes} disabled={disabled}>
      <slot />
    </button>
  )
}
