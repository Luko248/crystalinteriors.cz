---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireSession } from "@/lib/auth";
import { withBase } from "@/lib/navigation";

export const prerender = false;

const result = await requireSession(Astro);
if (result instanceof Response) return result;
---

<AdminLayout title="Přehled" session={result}>
  <h1 class="text-3xl text-foreground sm:text-4xl">Vítejte v administraci</h1>
  <p class="mt-3 max-w-2xl text-base leading-7 text-muted sm:text-lg">
    Tady spravujete obsah, který se hned promítá na veřejné stránky. Zatím jsou
    aktivní dvě sekce — galerie referencí a ceník služeb.
  </p>

  <ul class="mt-10 grid list-none gap-6 sm:grid-cols-2">
    <li>
      <a
        href={withBase("/admin/sections/")}
        class="group block h-full rounded-2xl border border-border bg-surface p-6 no-underline shadow-card transition-all duration-300 ease-standard hover:-translate-y-1 hover:border-primary/40 hover:shadow-lifted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background sm:p-7"
      >
        <p class="text-xs font-medium uppercase tracking-eyebrow text-primary">Sekce</p>
        <h2 class="mt-3 text-xl text-foreground sm:text-2xl">Galerie projektů</h2>
        <p class="mt-2 leading-7 text-muted">
          Spravujte kategorie referencí a nahrávejte fotky.
          Změny se hned objeví na stránce <code class="rounded bg-background px-1.5 py-0.5 text-sm">/projekty/</code>.
        </p>
        <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-primary transition-transform duration-300 ease-standard group-hover:translate-x-1">
          Otevřít →
        </span>
      </a>
    </li>

    <li>
      <a
        href={withBase("/admin/pricelist/")}
        class="group block h-full rounded-2xl border border-border bg-surface p-6 no-underline shadow-card transition-all duration-300 ease-standard hover:-translate-y-1 hover:border-primary/40 hover:shadow-lifted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background sm:p-7"
      >
        <p class="text-xs font-medium uppercase tracking-eyebrow text-primary">Sekce</p>
        <h2 class="mt-3 text-xl text-foreground sm:text-2xl">Ceník služeb</h2>
        <p class="mt-2 leading-7 text-muted">
          Upravte položky ceníku a jejich ceny. Změny se hned objeví na
          stránce <code class="rounded bg-background px-1.5 py-0.5 text-sm">/sluzby/</code>.
        </p>
        <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-primary transition-transform duration-300 ease-standard group-hover:translate-x-1">
          Otevřít →
        </span>
      </a>
    </li>
  </ul>
</AdminLayout>
