---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { readSession } from "@/lib/auth";

export const prerender = false;

const session = await readSession(Astro);
if (session) {
  return Astro.redirect("/admin/");
}

const error = Astro.url.searchParams.get("error");

const errorMessage = (() => {
  switch (error) {
    case null:
      return null;
    case "missing-token":
      return "Odkaz neobsahoval token.";
    case "expired":
      return "Odkaz expiroval. Vyžádejte nový.";
    case "bad-signature":
    case "malformed":
    case "wrong-purpose":
      return "Odkaz je neplatný.";
    case "email-not-allowed":
      return "Tento e-mail nemá přístup k administraci.";
    case "server-misconfigured":
      return "Server není správně nakonfigurován (chybí SESSION_SECRET).";
    default:
      return "Přihlášení selhalo. Zkuste to znovu.";
  }
})();
---

<AdminLayout title="Přihlášení">
  <div class="mx-auto max-w-md">
    <h1 class="text-2xl text-foreground sm:text-3xl">Přihlášení do administrace</h1>
    <p class="mt-3 text-sm leading-6 text-muted">
      Zadejte svůj e-mail. Pošleme vám jednorázový přihlašovací odkaz (platí 10 minut).
    </p>

    {
      errorMessage && (
        <p
          class="mt-6 rounded-xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-500"
          role="alert"
        >
          {errorMessage}
        </p>
      )
    }

    <form id="login-form" class="mt-6 flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm">
        <span class="font-medium text-foreground">E-mail</span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="vy@crystalinteriors.cz"
          class="h-11 rounded-xl border border-border bg-background px-4 text-foreground placeholder:text-subtle focus-visible:border-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
        />
      </label>

      <button
        type="submit"
        class="mt-2 inline-flex h-11 cursor-pointer items-center justify-center rounded-full bg-primary px-6 font-semibold text-white shadow-card transition-colors duration-fast ease-standard hover:bg-primary-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background disabled:opacity-50 disabled:pointer-events-none"
      >
        <span data-label-idle>Poslat odkaz</span>
        <span data-label-busy hidden>Odesílám…</span>
      </button>

      <p
        id="login-status"
        class="hidden text-sm leading-6 text-muted"
        role="status"
      >
      </p>
    </form>
  </div>

  <script is:inline>
    (() => {
      const form = document.getElementById("login-form");
      if (!form) return;
      const status = document.getElementById("login-status");
      const button = form.querySelector("button[type=submit]");
      const idle = form.querySelector("[data-label-idle]");
      const busy = form.querySelector("[data-label-busy]");

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const email = new FormData(form).get("email")?.toString().trim();
        if (!email) return;

        button.disabled = true;
        idle.hidden = true;
        busy.hidden = false;
        status.classList.add("hidden");

        try {
          const response = await fetch("/api/auth/request-link/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
          });
          if (!response.ok) {
            const data = await response.json().catch(() => ({}));
            throw new Error(data.error ?? `HTTP ${response.status}`);
          }
          status.textContent =
            "Pokud váš e-mail patří mezi povolené, odkaz vám právě dorazil. Zkontrolujte schránku (i spam).";
          status.classList.remove("hidden");
          form.reset();
        } catch (error) {
          status.textContent =
            error instanceof Error
              ? `Chyba: ${error.message}`
              : "Odeslání selhalo. Zkuste to znovu.";
          status.classList.remove("hidden");
        } finally {
          button.disabled = false;
          idle.hidden = false;
          busy.hidden = true;
        }
      });
    })();
  </script>
</AdminLayout>
