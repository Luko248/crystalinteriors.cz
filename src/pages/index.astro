---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import HeroSection from "@/components/HeroSection.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import Button from "@/components/ui/Button.astro";
import ArrowRightIcon from "@/components/icons/ArrowRightIcon.astro";
import ParallaxStrip from "@/components/ParallaxStrip.astro";
import { site } from "@/data/site";
import { cloudinaryImage } from "@/lib/cloudinary";
import { withBase } from "@/lib/navigation";

const heroPreload = cloudinaryImage(site.hero.image, {
  width: 1800,
  height: 1200,
  fit: "fill",
});
---

<BaseLayout
  title="Interiéry a nábytek na míru"
  description="Moderní redesign Crystal Interiors pro návrhy a realizace interiérů, kuchyní a zakázkového nábytku v Brně."
  pathname="/"
  preloadImage={heroPreload}
>
  <SiteHeader pathname={Astro.url.pathname} />
  <main id="main">
    <HeroSection />

    <section
      class="mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-20 lg:px-8 lg:py-28"
      aria-labelledby="approach-title"
    >
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-14">
        <SectionIntro
          eyebrow="Jak pracujeme"
          title={site.home.introTitle}
          text={site.home.introText}
          headingId="approach-title"
        />
        <div class="rounded-3xl border border-border bg-surface p-6 shadow-card sm:p-8">
          <p class="text-xl leading-8 text-foreground sm:text-2xl sm:leading-10 md:text-3xl">
            {site.home.businessSentence}
          </p>
        </div>
      </div>
    </section>

    <ParallaxStrip
      image={site.home.parallaxImage}
      eyebrow="Čím se zabýváme"
      title="Interiéry, kuchyně a nábytek na míru"
      text="Návrh, vizualizace a realizace v jedné lince — od dispozice po finální detail."
      tone="dark"
      height="md"
    />

    <section
      class="border-y border-border bg-surface py-14 sm:py-20 lg:py-28"
      aria-labelledby="services-title"
    >
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionIntro
          eyebrow="Služby"
          title="Od kuchyní po komerční interiéry"
          text="Navrhujeme prostory podle toho, jak se skutečně používají. Estetiku držíme ve stejné disciplíně jako funkci, rozpočet a výrobu."
          align="center"
          headingId="services-title"
        />

        <ul class="mt-10 grid list-none gap-6 sm:mt-14 md:grid-cols-2 xl:grid-cols-3">
          {
            site.services.map((service) => (
              <li>
                <article class="glass-hover h-full overflow-hidden rounded-xl border border-border bg-background shadow-card transition hover:-translate-y-1 hover:shadow-lifted">
                  <img
                    src={cloudinaryImage(service.image, {
                      width: 900,
                      height: 720,
                      fit: "fill",
                    })}
                    alt={`Ukázka služby — ${service.title}`}
                    width="900"
                    height="720"
                    class="aspect-[4/3] w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="space-y-3 p-6">
                    <h3 class="text-2xl text-foreground">{service.title}</h3>
                    <p class="leading-7 text-muted">{service.text}</p>
                  </div>
                </article>
              </li>
            ))
          }
        </ul>

        <div class="mt-10 flex justify-center">
          <Button as="a" href={withBase("/sluzby/")} variant="outline" size="lg" fullWidth rel={undefined}>
            Zobrazit služby a ceník
            <ArrowRightIcon class="h-5 w-5" />
          </Button>
        </div>
      </div>
    </section>

    <ParallaxStrip
      image={site.home.parallaxImage}
      eyebrow="Náš přístup"
      title="Návrh, materiál i realizace v jedné ruce"
      tone="dark"
      height="sm"
    />

    <section
      class="mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-20 lg:px-8 lg:py-28"
      aria-label="Náš přístup"
    >
      <ul class="grid list-none gap-6 sm:gap-8 md:grid-cols-2 lg:grid-cols-4">
        {
          site.process.map((item) => (
            <li class="rounded-xl border border-border bg-surface p-6">
              <p class="text-sm font-medium uppercase tracking-eyebrow text-primary">
                {item.title}
              </p>
              <p class="mt-4 leading-8 text-muted">{item.text}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section
      class="overflow-hidden bg-ink py-14 text-white sm:py-20 lg:py-24"
      aria-labelledby="cta-title"
    >
      <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-8 px-4 sm:px-6 lg:flex-row lg:items-center lg:px-8">
        <div class="max-w-3xl space-y-4">
          <p class="text-sm font-medium uppercase tracking-eyebrow text-white/60">
            Další krok
          </p>
          <h2 id="cta-title" class="text-2xl leading-tight sm:text-3xl md:text-5xl">
            Vytvoříme interiér přesně pro váš způsob bydlení nebo podnikání.
          </h2>
        </div>
        <Button
          as="a"
          href={withBase("/kontakt/")}
          variant="primary"
          size="lg"
          fullWidth
          rel={undefined}
          class="lg:w-auto"
        >
          Domluvit schůzku
          <ArrowRightIcon class="h-5 w-5" />
        </Button>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
