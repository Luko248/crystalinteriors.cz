---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import Button from "@/components/ui/Button.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="Kontakt"
  description="Kontaktujte Crystal Interiors kvůli návrhu kuchyně, interiéru nebo zakázkového nábytku."
  pathname="/kontakt/"
  breadcrumbs={[
    { name: "Úvod", href: "/" },
    { name: "Kontakt", href: "/kontakt/" },
  ]}
>
  <SiteHeader pathname={Astro.url.pathname} />
  <main id="main" class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-24">
    <SectionIntro
      eyebrow="Kontakt"
      title="Pojďme probrat váš interiér"
      text="Ať řešíte novou kuchyň, celý byt, dům nebo komerční prostor, první krok je jednoduchý: ozvěte se a sladíme rozsah, rozpočet i další postup."
    />

    <div class="mt-10 grid gap-6 sm:mt-12 sm:gap-8 lg:grid-cols-[0.95fr_1.05fr]">
      <address class="space-y-5 not-italic sm:space-y-6">
        <section
          class="rounded-2xl border border-border bg-surface p-6 sm:p-7"
          aria-labelledby="contact-address-label"
        >
          <p id="contact-address-label" class="text-sm font-medium uppercase tracking-eyebrow text-primary">Ateliér</p>
          <p class="mt-3 text-lg leading-7 text-foreground sm:text-xl sm:leading-8">{site.company.address}</p>
        </section>

        <section
          class="rounded-2xl border border-border bg-surface p-6 sm:p-7"
          aria-labelledby="contact-phone-label"
        >
          <p id="contact-phone-label" class="text-sm font-medium uppercase tracking-eyebrow text-primary">Telefon</p>
          <ul class="mt-3 grid list-none gap-2">
            {site.company.phones.map((phone) => (
              <li>
                <a
                  href={`tel:${phone.replace(/\s+/g, "")}`}
                  class="text-lg text-foreground hover:text-primary sm:text-xl"
                  aria-label={`Zavolat na číslo ${phone}`}
                >
                  {phone}
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section
          class="rounded-2xl border border-border bg-surface p-6 sm:p-7"
          aria-labelledby="contact-email-label"
        >
          <p id="contact-email-label" class="text-sm font-medium uppercase tracking-eyebrow text-primary">E-mail</p>
          <ul class="mt-3 grid list-none gap-2">
            {site.company.emails.map((email) => (
              <li>
                <a
                  href={`mailto:${email}`}
                  class="break-words text-base text-foreground hover:text-primary sm:text-lg"
                  aria-label={`Napsat e-mail na ${email}`}
                >
                  {email}
                </a>
              </li>
            ))}
          </ul>
        </section>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <Button as="a" href={`mailto:${site.company.emails[0]}`} variant="primary" size="lg" fullWidth rel={undefined}>
            Napsat e-mail
          </Button>
          <Button as="a" href={`tel:${site.company.phones[0].replace(/\s+/g, "")}`} variant="outline" size="lg" fullWidth rel={undefined}>
            Zavolat
          </Button>
        </div>
      </address>

      <div class="overflow-hidden rounded-3xl border border-border bg-surface shadow-card">
        <iframe
          src={site.company.mapEmbed}
          class="h-[360px] w-full sm:h-[460px] lg:h-[520px]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa — sídlo Crystal Interiors, Dusíkova 900/3c, Brno-Lesná"
        ></iframe>
      </div>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
