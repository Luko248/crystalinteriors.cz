---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import Button from "@/components/ui/Button.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="Kontakt"
  description="Kontaktujte Crystal Interiors kvůli návrhu kuchyně, interiéru nebo zakázkového nábytku."
  pathname="/kontakt/"
>
  <SiteHeader pathname={Astro.url.pathname} />
  <main class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <SectionIntro
      eyebrow="Kontakt"
      title="Pojďme probrat váš interiér"
      text="Ať řešíte novou kuchyň, celý byt, dům nebo komerční prostor, první krok je jednoduchý: ozvěte se a sladíme rozsah, rozpočet i další postup."
    />

    <div class="mt-12 grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="space-y-6">
        <div class="rounded-[1.75rem] border border-black/8 bg-surface p-7 dark:border-white/8">
          <p class="text-sm font-medium uppercase tracking-[0.22em] text-primary">Ateliér</p>
          <p class="mt-3 text-xl leading-8 text-foreground">{site.company.address}</p>
        </div>

        <div class="rounded-[1.75rem] border border-black/8 bg-surface p-7 dark:border-white/8">
          <p class="text-sm font-medium uppercase tracking-[0.22em] text-primary">Telefon</p>
          <div class="mt-3 grid gap-2">
            {site.company.phones.map((phone) => <a href={`tel:${phone.replace(/\s+/g, "")}`} class="text-xl text-foreground hover:text-primary">{phone}</a>)}
          </div>
        </div>

        <div class="rounded-[1.75rem] border border-black/8 bg-surface p-7 dark:border-white/8">
          <p class="text-sm font-medium uppercase tracking-[0.22em] text-primary">E-mail</p>
          <div class="mt-3 grid gap-2">
            {site.company.emails.map((email) => <a href={`mailto:${email}`} class="text-lg text-foreground hover:text-primary">{email}</a>)}
          </div>
        </div>

        <div class="flex flex-wrap gap-3">
          <Button as="a" href={`mailto:${site.company.emails[0]}`} variant="primary" size="lg" rel={undefined}>
            Napsat e-mail
          </Button>
          <Button as="a" href={`tel:${site.company.phones[0].replace(/\s+/g, "")}`} variant="outline" size="lg" rel={undefined}>
            Zavolat
          </Button>
        </div>
      </div>

      <div class="overflow-hidden rounded-[2rem] border border-black/8 bg-surface shadow-sm dark:border-white/8">
        <iframe
          src={site.company.mapEmbed}
          class="h-[520px] w-full"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Crystal Interiors mapa"
        ></iframe>
      </div>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
