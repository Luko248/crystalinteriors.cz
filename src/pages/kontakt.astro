---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import EnvelopeIcon from "@/components/icons/EnvelopeIcon.astro";
import PhoneIcon from "@/components/icons/PhoneIcon.astro";
import MapPinIcon from "@/components/icons/MapPinIcon.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="Kontakt"
  description="Kontaktujte Crystal Interiors kvůli návrhu kuchyně, interiéru nebo zakázkového nábytku."
  pathname="/kontakt/"
  breadcrumbs={[
    { name: "Úvod", href: "/" },
    { name: "Kontakt", href: "/kontakt/" },
  ]}
>
  <SiteHeader pathname={Astro.url.pathname} />
  <main id="main" class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-24">
    <SectionIntro
      eyebrow="Kontakt"
      title="Pojďme probrat váš interiér"
      text="Ať řešíte novou kuchyň, celý byt, dům nebo komerční prostor, první krok je jednoduchý: ozvěte se a sladíme rozsah, rozpočet i další postup."
    />

    <ul class="mt-10 grid list-none gap-6 sm:mt-12 md:grid-cols-2">
      {
        site.company.contacts.map((contact) => {
          const telHref = `tel:${contact.phone.replace(/\s+/g, "")}`;
          return (
            <li>
              <article class="flex h-full flex-col rounded-2xl border border-border bg-surface p-6 shadow-card sm:p-8">
                <header>
                  <p class="text-xs font-medium uppercase tracking-eyebrow text-primary sm:text-sm">
                    {contact.role}
                  </p>
                  <h2 class="mt-2 text-2xl text-foreground sm:text-3xl">
                    {contact.name}
                  </h2>
                </header>

                <div class="mt-6 flex flex-col gap-3">
                  <a
                    href={`mailto:${contact.email}`}
                    class="group flex items-center gap-3 rounded-xl border border-border bg-background px-4 py-3 text-foreground transition-colors duration-fast ease-standard hover:border-primary hover:text-primary focus-visible:border-primary focus-visible:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
                    aria-label={`Napsat e-mail — ${contact.name} (${contact.email})`}
                  >
                    <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary transition-colors duration-fast ease-standard group-hover:bg-primary group-hover:text-white">
                      <EnvelopeIcon class="h-4 w-4" />
                    </span>
                    <span class="break-all text-sm sm:text-base">{contact.email}</span>
                  </a>

                  <a
                    href={telHref}
                    class="group flex items-center gap-3 rounded-xl border border-border bg-background px-4 py-3 text-foreground transition-colors duration-fast ease-standard hover:border-primary hover:text-primary focus-visible:border-primary focus-visible:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
                    aria-label={`Zavolat — ${contact.name} (${contact.phone})`}
                  >
                    <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary transition-colors duration-fast ease-standard group-hover:bg-primary group-hover:text-white">
                      <PhoneIcon class="h-4 w-4" />
                    </span>
                    <span class="text-sm sm:text-base">{contact.phone}</span>
                  </a>
                </div>
              </article>
            </li>
          );
        })
      }
    </ul>

    <div class="mt-6 grid gap-6 sm:mt-8 sm:gap-8 lg:grid-cols-[0.6fr_1.4fr]">
      <address
        class="flex h-full flex-col rounded-2xl border border-border bg-surface p-6 not-italic shadow-card sm:p-7 lg:self-start"
        aria-labelledby="contact-address-label"
      >
        <div class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
            <MapPinIcon class="h-5 w-5" />
          </span>
          <p id="contact-address-label" class="text-xs font-medium uppercase tracking-eyebrow text-primary sm:text-sm">
            Ateliér
          </p>
        </div>

        <p class="mt-4 text-base leading-7 text-muted sm:text-lg sm:leading-8">
          Najdete nás v Brně-Lesné. Rádi vám pomůžeme s návrhem i realizací — stavte se u nás ve vzorkovně nebo si domluvte schůzku.
        </p>

        <p class="mt-4 text-lg leading-7 text-foreground sm:text-xl sm:leading-8">
          {site.company.address}
        </p>
      </address>

      <div class="self-start overflow-hidden rounded-3xl border border-border shadow-card">
        <iframe
          src={site.company.mapEmbed}
          class="block h-[360px] w-full sm:h-[460px] lg:h-[520px]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa — sídlo Crystal Interiors, Dusíkova 900/3c, Brno-Lesná"
        ></iframe>
      </div>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
