---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="O nás"
  description="Crystal Interiors tvoří dvě zkušené designérky zaměřené na interiéry, nábytek na míru a funkční realizaci."
  pathname="/o-nas/"
  breadcrumbs={[
    { name: "Úvod", href: "/" },
    { name: "O nás", href: "/o-nas/" },
  ]}
>
  <SiteHeader pathname={Astro.url.pathname} />
  <main id="main" class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <SectionIntro eyebrow="O studiu" title={site.about.title} text={site.about.lead} />

    <div class="mt-12 space-y-8 rounded-3xl border border-border bg-surface p-8 md:p-12">
      {site.about.paragraphs.map((paragraph) => <p class="text-lg leading-9 text-muted">{paragraph}</p>)}
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
