---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import ReferencesGallery from "@/components/ReferencesGallery.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="Reference"
  description="Reference Crystal Interiors podle typu prostoru — kuchyně, obývací pokoje, ložnice, koupelny i komerční interiéry."
  pathname="/projekty/"
  breadcrumbs={[
    { name: "Úvod", href: "/" },
    { name: "Reference", href: "/projekty/" },
  ]}
>
  <SiteHeader pathname={Astro.url.pathname} />
  <main id="main" class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-24">
    <SectionIntro
      eyebrow="Reference"
      title="Realizace a vizualizace podle typu prostoru"
      text="Vyberte si typ interiéru a prohlédněte si výběr našich realizací i vizualizací. Galerie se načítají přímo z naší Cloudinary knihovny."
    />

    <div class="mt-10 sm:mt-12">
      {site.references.map((category) => <ReferencesGallery category={category} />)}
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  import { Fancybox } from "@fancyapps/ui";
  import "@fancyapps/ui/dist/fancybox/fancybox.css";

  type CloudinaryResource = {
    public_id: string;
    format: string;
    width: number;
    height: number;
    version?: number;
  };

  const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME as
    | string
    | undefined;

  const buildUrl = (
    transforms: string,
    res: CloudinaryResource,
  ) => {
    const version = res.version ? `v${res.version}/` : "";
    return `https://res.cloudinary.com/${cloudName}/image/upload/${transforms}/${version}${res.public_id}.${res.format}`;
  };

  const escape = (value: string) =>
    value.replace(/[&<>"']/g, (char) =>
      char === "&"
        ? "&amp;"
        : char === "<"
          ? "&lt;"
          : char === ">"
            ? "&gt;"
            : char === '"'
              ? "&quot;"
              : "&#39;",
    );

  const renderTile = (
    res: CloudinaryResource,
    galleryId: string,
    title: string,
    index: number,
  ) => {
    const alt = `${title} — reference ${index + 1}`;
    const thumb = buildUrl("f_auto,q_auto,w_900,c_limit", res);
    const full = buildUrl("f_auto,q_auto,w_1920,c_limit", res);

    const item = document.createElement("li");
    item.className = "mb-6 break-inside-avoid";

    const link = document.createElement("a");
    link.href = full;
    link.dataset.fancybox = galleryId;
    link.dataset.caption = alt;
    link.setAttribute("aria-label", `Otevřít obrázek — ${alt}`);
    link.className =
      "glass-hover group relative block overflow-hidden rounded-lg bg-surface shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-lifted";
    link.innerHTML = `
      <img
        src="${escape(thumb)}"
        alt="${escape(alt)}"
        width="${res.width}"
        height="${res.height}"
        loading="lazy"
        decoding="async"
        class="h-auto w-full transform transition-transform duration-500 group-hover:scale-105"
      />
    `;
    item.appendChild(link);
    return item;
  };

  async function loadSection(section: HTMLElement) {
    const tag = section.dataset.tag;
    const galleryId = section.dataset.galleryId ?? tag ?? "references";
    const title = section.dataset.title ?? "";
    const live = section.querySelector<HTMLElement>("[data-references-live]");
    const grid = section.querySelector<HTMLUListElement>(
      "[data-references-grid]",
    );
    const status = section.querySelector<HTMLElement>(
      "[data-references-status]",
    );

    const settle = () => {
      live?.setAttribute("aria-busy", "false");
    };

    if (!grid || !tag) {
      settle();
      return;
    }

    if (!cloudName) {
      if (status) {
        status.textContent =
          "Reference se připravují. Galerie se zobrazí po propojení s Cloudinary.";
      }
      settle();
      return;
    }

    try {
      const response = await fetch(
        `https://res.cloudinary.com/${cloudName}/image/list/${tag}.json`,
        { cache: "no-cache" },
      );
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = (await response.json()) as {
        resources?: CloudinaryResource[];
      };
      const resources = data.resources ?? [];

      if (!resources.length) {
        if (status) status.textContent = "Reference se připravují.";
        settle();
        return;
      }

      resources.forEach((res, i) => {
        grid.appendChild(renderTile(res, galleryId, title, i));
      });
      grid.classList.remove("hidden");
      status?.remove();
    } catch (error) {
      console.warn(`References for "${tag}" failed to load`, error);
      if (status) {
        status.textContent = "Reference se nepodařilo načíst.";
      }
    } finally {
      settle();
    }
  }

  async function init() {
    const sections = document.querySelectorAll<HTMLElement>(
      "[data-references-section]",
    );
    await Promise.all(Array.from(sections).map(loadSection));

    Fancybox.bind("[data-fancybox]", {
      Hash: true,
      Toolbar: {
        display: {
          left: ["infobar"],
          middle: [],
          right: ["slideshow", "thumbs", "close"],
        },
      },
      Images: { zoom: true },
    } as unknown as Parameters<typeof Fancybox.bind>[1]);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
  document.addEventListener("astro:page-load", init);
</script>
