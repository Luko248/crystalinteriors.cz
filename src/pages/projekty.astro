---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import ProjectGallerySection from "@/components/ProjectGallerySection.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="Projekty"
  description="Portfolio vizualizací a realizovaných interiérů Crystal Interiors."
  pathname="/projekty/"
>
  <SiteHeader pathname={Astro.url.pathname} />
  <main class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <SectionIntro
      eyebrow="Portfolio"
      title="Realizované projekty a vybrané vizualizace"
      text="Ukázky projektů napříč rezidenčními i komerčními interiéry. Každá reference spojuje návrh prostoru, materiálové rozhodnutí a reálnou použitelnost."
    />

    <div class="mt-12">
      {
        site.projects.map((project, index) => (
          <ProjectGallerySection project={project} index={index} />
        ))
      }
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
