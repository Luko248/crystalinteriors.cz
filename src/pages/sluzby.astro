---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import Button from "@/components/ui/Button.astro";
import { site } from "@/data/site";
import { withBase } from "@/lib/navigation";
---

<BaseLayout
  title="Služby a ceník"
  description="Kompletní návrhy a realizace interiérů, 2D a 3D vizualizace, kuchyně a nábytek na míru."
  pathname="/sluzby/"
  breadcrumbs={[
    { name: "Úvod", href: "/" },
    { name: "Služby", href: "/sluzby/" },
  ]}
>
  <SiteHeader pathname={Astro.url.pathname} />
  <main id="main">
    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
      <SectionIntro
        eyebrow="Služby"
        title="Návrh, vizualizace i realizace"
        text="Poskytujeme kompletní designérské služby od první konzultace po hotový interiér. Navrhujeme kuchyně, interiéry a komerční prostory s důrazem na funkci, detail a rozumné rozhodování."
      />

      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        <article class="rounded-[1.75rem] border border-black/8 bg-surface p-8 dark:border-white/8">
          <p class="text-sm font-medium uppercase tracking-[0.22em] text-primary">
            Realizace interiérů a nábytku na míru
          </p>
          <h2 class="mt-4 text-3xl text-foreground">Od návrhu po montáž</h2>
          <p class="mt-4 leading-8 text-muted">
            Připravíme interiér jako celek. Řešíme dispozici, materiály, spotřebiče, nábytek, detaily i návaznost na výrobu a montáž.
          </p>
        </article>

        <article class="rounded-[1.75rem] border border-black/8 bg-surface p-8 dark:border-white/8">
          <p class="text-sm font-medium uppercase tracking-[0.22em] text-primary">
            Návrhy interiérů 2D a 3D
          </p>
          <h2 class="mt-4 text-3xl text-foreground">Jistota před realizací</h2>
          <p class="mt-4 leading-8 text-muted">
            Vizualizace používáme jako pracovní nástroj. Pomáhají ověřit dispozici, proporce, materiály i atmosféru prostoru ještě před výrobou.
          </p>
        </article>
      </div>
    </section>

    <section class="border-y border-black/8 bg-surface py-16 dark:border-white/8 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionIntro
          eyebrow="Ceník vizualizací"
          title="Orientační ceny"
          text="Cena se odvíjí od rozsahu, složitosti a typu prostoru. Níže uvádíme základní orientaci pro první plánování projektu."
        />

        <div class="mt-12 grid gap-4 md:grid-cols-2">
          {
            site.pricing.map((item) => (
              <div class="flex items-center justify-between gap-4 rounded-2xl border border-black/8 bg-background px-5 py-4 dark:border-white/8">
                <span class="leading-7 text-foreground">{item.title}</span>
                <strong class="shrink-0 text-primary">{item.price}</strong>
              </div>
            ))
          }
        </div>

        <div class="mt-10">
          <Button as="a" href={withBase("/kontakt/")} variant="primary" size="lg" rel={undefined}>
            Poptat projekt
          </Button>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
